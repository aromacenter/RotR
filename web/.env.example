# Railway / production környezeti változók

# Bejelentkezési adatok
ADMIN_USERNAME=admin
ADMIN_PASSWORD=valtozd_meg_ezt

# Anthropic API kulcs (szükséges a PDF elemzéshez)
ANTHROPIC_API_KEY=sk-ant-...

# Session titkosítás (kötelező megváltoztatni production-ben!)
SESSION_SECRET=valami_teljesen_titkos_string_ide

# Adatbázis elérési út (Railway perzisztens kötet esetén: /data/rota.db)
# DB_PATH=/data/rota.db

# Port (Railway automatikusan beállítja)
# PORT=3000
